# ==============================================
# MapProject Environment Variables - TEMPLATE
# Bu dosyayi kopyalayip .env olarak kaydedin
# cp .env.example .env
# ==============================================

# --- MapProject.Api ---

# MongoDB
DatabaseSettings__ConnectionString=mongodb+srv://<kullanici>:<sifre>@<cluster>.mongodb.net/
DatabaseSettings__DatabaseName=Project
DatabaseSettings__MapIdentityDescriptionCollectionName=MapIdentityDescriptions
DatabaseSettings__CategoryCollectionName=Categories
DatabaseSettings__ContactCollectionName=Contacts
DatabaseSettings__UserInformationCollectionName=Users
DatabaseSettings__UsersIdentityCollectionName=AppUsers
DatabaseSettings__RolesIdentityCollectionName=AppRoles
DatabaseSettings__VisitorLogCollectionName=VisitorLogs

# JWT
JWTSecurity__SecretKey=<en_az_32_karakter_uzun_guclu_bir_anahtar>

# --- MapProject.WebUI ---

# API Base URL (Docker Compose icinde api servisi adi kullanilir)
ApiSettings__BaseUrl=http://api:8080

# Email (SMTP)
EmailSettings__Host=smtp.gmail.com
EmailSettings__Port=465
EmailSettings__UseSsl=true
EmailSettings__SenderEmail=<gonderen@gmail.com>
EmailSettings__SenderName=<Gonderen Adi>
EmailSettings__Password=<gmail_uygulama_sifresi>
EmailSettings__ReceiverEmail=<alici@gmail.com>
