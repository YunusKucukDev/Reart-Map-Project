@using MapProject.DtoLayer.DTOs.CategoryDto
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@model List<ResultCategoryDto>
@{
    string _apiBase = Configuration["ApiSettings:BaseUrl"] ?? "https://reart-map-project-api.onrender.com";
    string _img(string? p) => string.IsNullOrEmpty(p) ? "" : (p.StartsWith("http") ? p : _apiBase + (p.StartsWith("/") ? p : "/" + p));
}

<div class="container-fluid py-5">
    <div class="container">
        <div class="text-center mx-auto mb-5" style="max-width: 500px;">
            <h5 class="d-inline-block text-primary text-uppercase border-bottom border-5">Reart Ajans</h5>
            <h1 class="display-4">En çok Tercih Edilen Haritalarımız</h1>
        </div>
        <div class="owl-carousel price-carousel position-relative" style="padding: 0 45px 45px 45px;">
            @foreach (var item in Model)
            {
                <div class="bg-light rounded text-center">
                    <div class="position-relative">
                        <img class="img-fluid rounded-top" src="@_img(item.ImageUrl1)" alt="@item.CategoryName">
                        <div class="position-absolute w-100 h-100 top-50 start-50 translate-middle rounded-top d-flex flex-column align-items-center justify-content-center"
                             style="background: rgba(29, 42, 77, .4);">
                            <h3 class="text-white">@item.CategoryName</h3>
                        </div>
                    </div>
                    <div class="text-center py-5">  
                        <a href="/category/details/@item.Id" class="btn btn-primary rounded-pill py-3 px-5 my-2">Detaylar</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>