@using MapProject.DtoLayer.DTOs.UserInformationDto
@model ResultUserInformationDto

<div class="col-lg-3 col-md-6">
    <h6 class="text-primary text-uppercase mt-4 mb-3">Follow Us</h6>
    <div class="d-flex">
        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle me-2" href="@Model.XLink">
            <i class="fab fa-twitter"></i>
        </a>
        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle me-2" href="@Model.WPLink">
            <i class="fab fa-whatsapp"></i>
        </a>
        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle me-2" href="@Model.LinkednLink">
            <i class="fab fa-linkedin-in"></i>
        </a>
        <a class="btn btn-lg btn-primary btn-lg-square rounded-circle" href="@Model.InstagramLink">
            <i class="fab fa-instagram"></i>
        </a>
    </div>
</div> 