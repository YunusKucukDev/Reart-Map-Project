@using MapProject.DtoLayer.DTOs.UserInformationDto
@model ResultUserInformationDto

<div class="row g-4 mb-5">
    <div class="col-12 col-md-4">
        <div class="bg-light rounded d-flex flex-column align-items-center justify-content-center text-center py-4 px-3">
            <div class="d-flex align-items-center justify-content-center bg-primary rounded-circle mb-3"
                 style="width: 64px; height: 64px; transform: rotate(-15deg);">
                <i class="fa fa-2x fa-location-arrow text-white" style="transform: rotate(15deg);"></i>
            </div>
            <h6 class="mb-0">@Model.Address</h6>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="bg-light rounded d-flex flex-column align-items-center justify-content-center text-center py-4 px-3">
            <div class="d-flex align-items-center justify-content-center bg-primary rounded-circle mb-3"
                 style="width: 64px; height: 64px; transform: rotate(-15deg);">
                <i class="fa fa-2x fa-phone text-white" style="transform: rotate(15deg);"></i>
            </div>
            <h6 class="mb-0">@Model.PhoneNumber</h6>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="bg-light rounded d-flex flex-column align-items-center justify-content-center text-center py-4 px-3">
            <div class="d-flex align-items-center justify-content-center bg-primary rounded-circle mb-3"
                 style="width: 64px; height: 64px; transform: rotate(-15deg);">
                <i class="fa fa-2x fa-envelope-open text-white" style="transform: rotate(15deg);"></i>
            </div>
            <h6 class="mb-0">@Model.Email</h6>
        </div>
    </div>
</div> 