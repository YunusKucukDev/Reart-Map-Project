                <div class="process-mobile-item last" data-step="5">
                    <div class="process-mobile-icon active">
                        <i class="fa fa-check-circle"></i>
                        <span class="process-mobile-number">5</span>
                    </div>
                    <div class="process-mobile-content">
                        <span class="process-mobile-duration"><i class="fa fa-clock me-1"></i>1 Gün</span>
                        <h5>Teslim Edilir</h5>
                        <p>Tamamlanan ürün kalite kontrolünden geçirilerek size teslim edilir. Mutlu müşteri, bizim başarımız!</p>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<style>
    /* ===== WORK PROCESS SECTION ===== */
    .work-process-section {
        background: linear-gradient(135deg, #f8fbff 0%, #eef6fb 100%);
    }

    /* ===== DESKTOP TIMELINE ===== */
    .process-timeline {
        position: relative;
        padding: 60px 0 20px;
    }

    .process-line,
    .process-line-animated {
        position: absolute;
        top: 60px;
        left: 10%;
        right: 10%;
        height: 3px;
        border-radius: 3px;
    }

    .process-line {
        background: #dee2e6;
        z-index: 0;
    }

    .process-line-animated {
        background: linear-gradient(90deg, #13C5DD, #354F8E);
        z-index: 1;
        width: 0;
        transition: width 2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .process-line-animated.animated {
        width: 80%;
    }

    /* ===== STEP CARD ===== */
    .process-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 2;
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .process-step.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .process-step:nth-child(1) { transition-delay: 0.1s; }
    .process-step:nth-child(2) { transition-delay: 0.3s; }
    .process-step:nth-child(3) { transition-delay: 0.5s; }
    .process-step:nth-child(4) { transition-delay: 0.7s; }
    .process-step:nth-child(5) { transition-delay: 0.9s; }

    .process-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
    }

    /* Icon */
    .process-icon-wrap {
        position: relative;
        margin-bottom: 0;
    }

    .process-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #13C5DD, #354F8E);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 26px;
        box-shadow: 0 8px 25px rgba(19, 197, 221, 0.35);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: default;
    }

    .process-step:hover .process-icon {
        transform: scale(1.12) translateY(-4px);
        box-shadow: 0 14px 35px rgba(19, 197, 221, 0.5);
    }

    .process-number {
        position: absolute;
        top: -8px;
        right: -8px;
        width: 24px;
        height: 24px;
        background: #354F8E;
        border-radius: 50%;
        color: #fff;
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    /* Dot connector */
    .process-dot {
        width: 14px;
        height: 14px;
        background: #13C5DD;
        border-radius: 50%;
        border: 3px solid #fff;
        box-shadow: 0 0 0 3px #13C5DD;
        margin: 10px 0;
        transition: background 0.4s ease, box-shadow 0.4s ease;
    }

    .process-step.visible .process-dot {
        background: linear-gradient(135deg, #13C5DD, #354F8E);
        box-shadow: 0 0 0 3px #354F8E;
    }

    /* Body */
    .process-body {
        background: #fff;
        border-radius: 12px;
        padding: 18px 14px;
        text-align: center;
        box-shadow: 0 4px 20px rgba(0,0,0,0.07);
        border-top: 3px solid #13C5DD;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        width: 100%;
    }

    .process-step:hover .process-body {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(19, 197, 221, 0.18);
    }

    .process-duration {
        display: inline-block;
        background: linear-gradient(135deg, #13C5DD22, #354F8E22);
        color: #354F8E;
        font-size: 11px;
        font-weight: 700;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: 8px;
        letter-spacing: 0.5px;
    }

    .process-title {
        font-size: 15px;
        font-weight: 700;
        color: #1D2A4D;
        margin-bottom: 6px;
    }

    .process-desc {
        font-size: 12.5px;
        color: #6c757d;
        line-height: 1.5;
        margin: 0;
    }

    /* ===== MOBILE TIMELINE ===== */
    .process-mobile-timeline {
        position: relative;
        padding: 10px 0;
    }

    .process-mobile-item {
        display: flex;
        align-items: flex-start;
        gap: 16px;
        margin-bottom: 0;
        opacity: 0;
        transform: translateX(-20px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .process-mobile-item.visible {
        opacity: 1;
        transform: translateX(0);
    }

    .process-mobile-item:nth-child(1) { transition-delay: 0.1s; }
    .process-mobile-item:nth-child(2) { transition-delay: 0.25s; }
    .process-mobile-item:nth-child(3) { transition-delay: 0.4s; }
    .process-mobile-item:nth-child(4) { transition-delay: 0.55s; }
    .process-mobile-item:nth-child(5) { transition-delay: 0.7s; }

    .process-mobile-icon {
        position: relative;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .process-mobile-icon i {
        width: 54px;
        height: 54px;
        background: linear-gradient(135deg, #13C5DD, #354F8E);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 20px;
        box-shadow: 0 6px 18px rgba(19, 197, 221, 0.3);
    }

    .process-mobile-number {
        position: absolute;
        top: -6px;
        right: -6px;
        width: 20px;
        height: 20px;
        background: #354F8E;
        border-radius: 50%;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    .process-mobile-line {
        width: 2px;
        flex: 1;
        background: linear-gradient(180deg, #13C5DD, #354F8E);
        margin: 8px auto 0;
        min-height: 40px;
        border-radius: 2px;
    }

    .process-mobile-content {
        background: #fff;
        border-radius: 10px;
        padding: 14px 16px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
        border-left: 3px solid #13C5DD;
        flex: 1;
        margin-bottom: 20px;
    }

    .process-mobile-duration {
        display: inline-block;
        background: linear-gradient(135deg, #13C5DD22, #354F8E22);
        color: #354F8E;
        font-size: 11px;
        font-weight: 700;
        padding: 2px 10px;
        border-radius: 20px;
        margin-bottom: 6px;
    }

    .process-mobile-content h5 {
        font-size: 15px;
        font-weight: 700;
        color: #1D2A4D;
        margin-bottom: 4px;
    }

    .process-mobile-content p {
        font-size: 13px;
        color: #6c757d;
        line-height: 1.5;
        margin: 0;
    }

    .process-mobile-item.last .process-mobile-icon i {
        background: linear-gradient(135deg, #28a745, #20c997);
        box-shadow: 0 6px 18px rgba(40, 167, 69, 0.3);
    }

    .process-mobile-item.last .process-mobile-content {
        border-left-color: #28a745;
    }

    /* Pulse animation on last step */
    @@keyframes pulse-green {
        0%   { box-shadow: 0 6px 18px rgba(40, 167, 69, 0.3); }
        50%  { box-shadow: 0 6px 30px rgba(40, 167, 69, 0.65); }
        100% { box-shadow: 0 6px 18px rgba(40, 167, 69, 0.3); }
    }

    .process-mobile-item.last.visible .process-mobile-icon i {
        animation: pulse-green 2s ease-in-out infinite;
    }

    @@keyframes pulse-icon {
        0%   { box-shadow: 0 8px 25px rgba(19, 197, 221, 0.35); }
        50%  { box-shadow: 0 8px 35px rgba(19, 197, 221, 0.7); }
        100% { box-shadow: 0 8px 25px rgba(19, 197, 221, 0.35); }
    }

    .process-step:last-child .process-icon {
        background: linear-gradient(135deg, #28a745, #20c997);
        animation: pulse-icon 2s ease-in-out infinite;
    }

    .process-step:last-child .process-body {
        border-top-color: #28a745;
    }

    .process-step:last-child .process-duration {
        background: linear-gradient(135deg, #28a74522, #20c99722);
        color: #28a745;
    }
</style>

<script>
    (function () {
        function initWorkProcess() {
            var section = document.querySelector('.work-process-section');
            if (!section) return;

            var steps = section.querySelectorAll('.process-step, .process-mobile-item');
            var line  = section.querySelector('.process-line-animated');
            var triggered = false;

            function activate() {
                if (triggered) return;
                var rect = section.getBoundingClientRect();
                if (rect.top < window.innerHeight * 0.82) {
                    triggered = true;
                    if (line) line.classList.add('animated');
                    steps.forEach(function (el) { el.classList.add('visible'); });
                    window.removeEventListener('scroll', activate);
                }
            }

            window.addEventListener('scroll', activate, { passive: true });
            activate(); // run once on load in case already in view
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initWorkProcess);
        } else {
            initWorkProcess();
        }
    })();
</script>
<!-- Work Process Section End -->
