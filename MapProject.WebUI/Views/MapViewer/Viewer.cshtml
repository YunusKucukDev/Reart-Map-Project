@model MapProject.DtoLayer.DTOs.MapViewerDto.GetByIdMapViewerDto
@{
    Layout = null;
    // API Domaininizi tek bir yerden yönetmek için değişken (Canlıya çıkarken değiştirin)
    string apiDomain = "https://localhost:5000";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="robots" content="noindex, nofollow">
    <title>@Model.Title | Reart Dijital Harita</title>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/openseadragon/4.1.0/openseadragon.min.js"></script>

    <style>
        /* ── TEMEL STİLLER ── */
        :root {
            --primary-color: #34cde2; /* Reart Ajans Turkuazı */
            --bg-color: #0d1117; /* Çok koyu gri/siyah */
            --text-color: #ffffff;
            --panel-bg: rgba(20, 25, 31, 0.85); /* Şeffaf koyu panel */
        }

        body {
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--text-color);
            overflow: hidden; /* Kaydırma çubuğunu engelle */
            height: 100vh;
            width: 100vw;
        }

        /* ── GÖRÜNTÜLEYİCİ KONTEYNERİ ── */
        #viewer-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            z-index: 1;
        }

        #openseadragon-viewer {
            width: 100%;
            height: 100%;
            background-color: transparent;
        }

        /* ── ÜST BİLGİ PANELİ (Header) ── */
        .map-header {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            padding: 15px 25px;
            background: linear-gradient(to bottom, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
            z-index: 10;
            display: flex;
            justify-content: space-between;
            align-items: center;
            pointer-events: none; /* Tıklamaları haritaya geçir */
        }

        .map-title-group {
            pointer-events: auto; /* Kendi içindeki tıklamaları aktif et */
        }

        .map-title {
            margin: 0;
            font-size: 1.25rem;
            font-weight: 600;
            letter-spacing: -0.5px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .map-subtitle {
            margin: 2px 0 0 0;
            font-size: 0.85rem;
            opacity: 0.7;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .brand-logo {
            color: var(--primary-color);
            font-weight: 800;
            font-size: 1.1rem;
            text-decoration: none;
            pointer-events: auto;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

       
        .map-footer-tip {
            position: absolute;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            padding: 10px 20px;
            background-color: var(--panel-bg);
            border-radius: 30px;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.08);
            font-size: 0.85rem;
            z-index: 10;
            pointer-events: none;
            opacity: 0;
            animation: fadeInOut 5s ease-in-out forwards; /* 5 saniye sonra kaybol */
            display: flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
        }

        .tip-icon {
            color: var(--primary-color);
            font-size: 1rem;
        }

      
        .openseadragon-container .buttons {
            margin-right: 20px !important;
            margin-bottom: 20px !important;
            background-color: var(--panel-bg) !important;
            border-radius: 8px !important;
            padding: 5px !important;
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.1);
        }

        /* Animasyonlar */
        @@keyframes fadeInOut {
            0% {
                opacity: 0;
                transform: translate(-50%, 10px);
            }

            10% {
                opacity: 1;
                transform: translate(-50%, 0);
            }

            80% {
                opacity: 1;
                transform: translate(-50%, 0);
            }

            100% {
                opacity: 0;
                transform: translate(-50%, -10px);
            }
        }

      
        @@media (max-width: 768px) {
            .map-header {
                padding: 10px 15px;
            }

            .map-title {
                font-size: 1rem;
            }

            .map-subtitle {
                font-size: 0.75rem;
            }

            .brand-logo {
                font-size: 0.9rem;
            }

            .map-footer-tip {
                font-size: 0.75rem;
                bottom: 70px; 
            }
        }

        
        img {
            -webkit-user-drag: none;
            -khtml-user-drag: none;
            -moz-user-drag: none;
            -o-user-drag: none;
            user-drag: none;
        }
    </style>
</head>
<body oncontextmenu="return false;" onselectstart="return false;" ondragstart="return false;">

    <header class="map-header">
        <div class="map-title-group">
            <h1 class="map-title">@Model.Title</h1>
            <p class="map-subtitle">Dijital Harita Görüntüleyici</p>
        </div>
        <a href="https://ajansreart.com" target="_blank" class="brand-logo">REART</a>
    </header>

    <div id="viewer-container">
        <div id="openseadragon-viewer"></div>
    </div>

    <div class="map-footer-tip">
        <span class="tip-icon">🔍</span>
        <span>Yakınlaştırmak için kaydırın veya çift tıklayın.</span>
    </div>

    <script>
       
        var viewer = OpenSeadragon({
            id: "openseadragon-viewer",
            prefixUrl: "https://cdnjs.cloudflare.com/ajax/libs/openseadragon/4.1.0/images/",

            tileSources: {
                type: 'image',
                url: '@apiDomain' + '@Model.ImageUrl'
            },

           
            animationTime: 1.2,
            blendTime: 0.1,
            constrainDuringPan: true, 
            maxZoomPixelRatio: 3, 
            minZoomLevel: 1,
            visibilityRatio: 1,

           
            showNavigationControl: true,
            navigationControlAnchor: OpenSeadragon.ControlAnchor.BOTTOM_RIGHT, // Sağ alta al
            gestureSettingsMouse: { clickToZoom: true, scrollToZoom: true },
            gestureSettingsTouch: { pinchToZoom: true, doubleTapToZoom: true },

            
            showZoomControl: true,
            showHomeControl: true,
            showFullPageControl: true
        });

        
        viewer.addHandler('open', function() {
            viewer.viewport.goHome(true);
        });
    </script>

    <script>
        // URL'yi tam yol olarak oluşturmayı deneyin
        var trackUrl = '@Url.Action("Track", "MapViewer")' + '/' + '@Model.Id';
        fetch(trackUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        })
        .then(response => console.log("Track isteği sonucu:", response.status))
        .catch(err => console.error("Track hatası:", err));
    </script>
</body>
</html>