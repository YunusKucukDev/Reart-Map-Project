@using MapProject.DtoLayer.DTOs.MapIdentityDescriptionDto
@model ResultMapIdentityDescriptionDto
@{
    ViewData["Title"] = "Harita Kimliği";
    Layout = "~/Views/UI/Index.cshtml";

    // KRİTİK AYAR: Resimlerin fiziksel olarak bulunduğu API adresi
    string apiBase = "https://localhost:5000";

    // Bu fonksiyon resim yolunu kontrol eder ve 5000 portuna yönlendirir
    string ResolvePath(string? path)
    {
        if (string.IsNullOrEmpty(path)) return "/img/placeholder.png";

        // Eğer veritabanından gelen yol zaten tam bir URL ise dokunma
        if (path.StartsWith("http")) return path;

        // Yolun başındaki eğik çizgiyi kontrol et ve apiBase ile birleştir
        var cleanPath = path.StartsWith("/") ? path : "/" + path;

        // SONUÇ: https://localhost:5000/images/resim.png
        return apiBase + cleanPath;
    }
}

<style>
    /* Hero Alanı */
    .mid-hero {
        background: linear-gradient(135deg, #1d2a4d 0%, #212529 60%, #13c5dd 100%);
        padding: 80px 0 60px;
        position: relative;
        overflow: hidden;
    }

        .mid-hero::before {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            background: rgba(19, 197, 221, 0.12);
            border-radius: 50%;
            top: -100px;
            right: -80px;
            animation: pulse-bg 6s ease-in-out infinite;
        }

    @@keyframes pulse-bg {
        0%, 100% {
            transform: scale(1);
            opacity: 0.7;
        }

        50% {
            transform: scale(1.15);
            opacity: 1;
        }
    }

    /* Bölümler */
    .map-identity-section {
        padding: 80px 0;
    }

        .map-identity-section:nth-child(even) {
            background-color: #f8f9fa;
        }

    /* Görsel Çerçevesi */
    .map-img-wrapper {
        position: relative;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(29, 42, 77, 0.18);
        background: #e9ecef; /* Resim gelene kadar dolgu */
    }

        .map-img-wrapper img {
            width: 100%;
            height: 400px;
            object-fit: cover;
            display: block;
            transition: transform 0.7s ease;
        }

        .map-img-wrapper:hover img {
            transform: scale(1.05);
        }

        .map-img-wrapper .img-badge {
            position: absolute;
            bottom: 20px;
            left: 20px;
            background: #13c5dd;
            color: #fff;
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 700;
            box-shadow: 0 4px 15px rgba(19, 197, 221, 0.4);
        }

    .text-primary-custom {
        color: #13c5dd !important;
    }

    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s ease-out;
    }

        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="mid-hero">
    <div class="container text-center position-relative" style="z-index:1;">
        <h5 class="text-white text-uppercase border-bottom border-5 d-inline-block mb-3" style="border-color: #13c5dd !important;">ReArt Ajans</h5>
        <h1 class="display-4 text-white fw-bold">Harita Kimliği</h1>
        <p class="text-white-50 mx-auto" style="max-width: 600px;">Her lokasyonun bir ruhu vardır. Biz o ruhu haritalarımıza nakşediyoruz.</p>
    </div>
</div>

@if (Model != null)
{
    <div class="map-identity-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 reveal">
                    <div class="map-img-wrapper">
                        <img src="@ResolvePath(Model.ImageUrl1)" alt="Görsel 1" />
                        <span class="img-badge">Vizyoner Bakış</span>
                    </div>
                </div>
                <div class="col-lg-6 reveal">
                    <h5 class="text-primary-custom text-uppercase fw-bold mb-3">Haritanın Özü</h5>
                    <h2 class="display-6 fw-bold mb-4">Bir Harita Sadece Yol Göstermez</h2>
                    <p class="lead text-muted">@Model.Description1</p>
                    <div class="d-flex gap-4 mt-4">
                        <div>
                            <h3 class="fw-bold text-primary-custom mb-0">@Model.Experincenumber+</h3>
                            <small class="text-uppercase text-muted">Yıllık Deneyim</small>
                        </div>
                        <div class="border-start ps-4">
                            <h3 class="fw-bold text-primary-custom mb-0">@Model.Projectnumber+</h3>
                            <small class="text-uppercase text-muted">Başarılı Proje</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="map-identity-section">
        <div class="container">
            <div class="row align-items-center g-5 flex-lg-row-reverse">
                <div class="col-lg-6 reveal">
                    <div class="map-img-wrapper">
                        <img src="@ResolvePath(Model.ImageUrl2)" alt="Görsel 2" />
                        <span class="img-badge" style="background:#1d2a4d">Stratejik Planlama</span>
                    </div>
                </div>
                <div class="col-lg-6 reveal">
                    <h5 class="text-primary-custom text-uppercase fw-bold mb-3">Küresel Perspektif</h5>
                    <h2 class="display-6 fw-bold mb-4">Detaylardaki Mükemmellik</h2>
                    <p class="lead text-muted">@Model.Description2</p>
                </div>
            </div>
        </div>
    </div>

    <div class="map-identity-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 reveal">
                    <div class="map-img-wrapper">
                        <img src="@ResolvePath(Model.ImageUrl3)" alt="Görsel 3" />
                        <span class="img-badge" style="background:#212529">Teknolojik Altyapı</span>
                    </div>
                </div>
                <div class="col-lg-6 reveal">
                    <h5 class="text-primary-custom text-uppercase fw-bold mb-3">Dijital Dönüşüm</h5>
                    <h2 class="display-6 fw-bold mb-4">Geleceği Bugün Çiziyoruz</h2>
                    <p class="lead text-muted">@Model.Description3</p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container py-5 text-center">
        <p class="text-muted">Harita verileri şu an yüklenemiyor. Lütfen daha sonra tekrar deneyiniz.</p>
    </div>
}

<script>
    // Sayfa kaydırıldığında elemanların belirmesi için
    document.addEventListener("DOMContentLoaded", function() {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    });
</script>