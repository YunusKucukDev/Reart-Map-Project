@model MapProject.DtoLayer.DTOs.VideoDto.CreateVideoDto
@{
    ViewData["Title"] = "Yeni Video";
    ViewData["ActiveMenu"] = "Video";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2 text-primary"></i>Yeni Video Ekle</h5>
            </div>
            <div class="card-body p-4">
                <form asp-area="Admin" asp-controller="AdminVideo" asp-action="Create"
                      method="post" enctype="multipart/form-data">

                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label fw-bold">Başlık</label>
                            <input asp-for="Title" class="form-control" placeholder="Video başlığı" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Tag" class="form-label fw-bold">Etiket</label>
                            <input asp-for="Tag" class="form-control" placeholder="Teknik, Referans..." />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Kısa video açıklaması..."></textarea>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Duration" class="form-label fw-bold">Süre <span class="text-muted fw-normal">(isteğe bağlı)</span></label>
                            <input asp-for="Duration" class="form-control" placeholder="5:30" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Order" class="form-label fw-bold">Sıra</label>
                            <input asp-for="Order" class="form-control" type="number" min="0" value="0" />
                        </div>
                    </div>

                    <hr class="text-muted mb-4" />

                    <!-- Video Dosyası -->
                    <h6 class="mb-3 text-secondary"><i class="bi bi-camera-video me-1"></i>Video Dosyası</h6>
                    <div class="mb-4">
                        <div id="videoDropZone" class="border border-2 border-dashed rounded-3 p-4 text-center"
                             style="cursor:pointer; border-color:#ced4da !important; transition:border-color .2s;">
                            <i class="bi bi-cloud-upload fs-2 text-muted d-block mb-2"></i>
                            <p class="mb-1 text-muted">Videoyu buraya sürükleyin veya tıklayın</p>
                            <small class="text-muted">MP4, MOV, AVI, MKV — maks. 500 MB</small>
                            <input type="file" name="videoFile" id="videoFile" class="d-none"
                                   accept="video/*" onchange="handleVideoSelect(this)" />
                        </div>
                        <div id="videoInfo" class="mt-2 d-none">
                            <div class="d-flex align-items-center gap-2 p-2 bg-light rounded">
                                <i class="bi bi-file-play text-primary fs-5"></i>
                                <span id="videoFileName" class="small fw-medium flex-grow-1 text-truncate"></span>
                                <span id="videoFileSize" class="small text-muted"></span>
                                <button type="button" class="btn btn-sm btn-outline-danger py-0" onclick="clearVideo()">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                            <div class="mt-2">
                                <video id="videoPreview" controls class="w-100 rounded" style="max-height:220px;"></video>
                            </div>
                        </div>
                    </div>

                    <!-- Thumbnail -->
                    <h6 class="mb-2 text-secondary"><i class="bi bi-image me-1"></i>Kapak Görseli <span class="text-muted fw-normal">(isteğe bağlı)</span></h6>
                    <div class="text-center mb-4">
                        <img src="/images/no-image.png" id="thumbPreview"
                             class="img-fluid rounded border mb-3 shadow-sm"
                             style="width:100%; max-height:180px; object-fit:cover;" />
                        <input type="file" name="thumbnailFile" id="thumbnailFile" class="d-none"
                               accept="image/*" onchange="updateThumbPreview(this)" />
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                onclick="document.getElementById('thumbnailFile').click()">
                            <i class="bi bi-image me-1"></i>Kapak Seç
                        </button>
                    </div>

                    <div class="pt-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Videoyu Kaydet
                        </button>
                        <a asp-action="Index" class="btn btn-light px-4 border">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var dropZone = document.getElementById('videoDropZone');
    var fileInput = document.getElementById('videoFile');

    dropZone.addEventListener('click', function () { fileInput.click(); });
    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropZone.style.borderColor = '#0d6efd';
        dropZone.style.background = '#f0f4ff';
    });
    dropZone.addEventListener('dragleave', function () {
        dropZone.style.borderColor = '#ced4da';
        dropZone.style.background = '';
    });
    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        dropZone.style.borderColor = '#ced4da';
        dropZone.style.background = '';
        if (e.dataTransfer.files.length) {
            fileInput.files = e.dataTransfer.files;
            handleVideoSelect(fileInput);
        }
    });

    function handleVideoSelect(input) {
        if (!input.files || !input.files[0]) return;
        var file = input.files[0];
        document.getElementById('videoFileName').textContent = file.name;
        document.getElementById('videoFileSize').textContent = formatSize(file.size);
        document.getElementById('videoInfo').classList.remove('d-none');
        dropZone.classList.add('d-none');

        var url = URL.createObjectURL(file);
        document.getElementById('videoPreview').src = url;
    }

    function clearVideo() {
        fileInput.value = '';
        document.getElementById('videoInfo').classList.add('d-none');
        dropZone.classList.remove('d-none');
        document.getElementById('videoPreview').src = '';
    }

    function formatSize(bytes) {
        if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
        return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function updateThumbPreview(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('thumbPreview').src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>
}
