@model List<ResultContactDto>
@{
    ViewData["Title"] = "Mesajlar";
    ViewData["ActiveMenu"] = "Contact";
}

<style>
    @@media (max-width: 767.98px) {
        .contact-table-wrap { display: none; }
        .contact-cards-wrap { display: block; }
    }
    @@media (min-width: 768px) {
        .contact-table-wrap { display: block; }
        .contact-cards-wrap { display: none; }
    }
    .contact-card {
        background: #fff;
        border-radius: 0.6rem;
        box-shadow: 0 1px 4px rgba(0,0,0,.08);
        padding: 1rem;
        margin-bottom: 0.75rem;
    }
    .contact-card-name    { font-weight: 600; font-size: 0.92rem; color: #1e293b; }
    .contact-card-email   { font-size: 0.8rem; color: #64748b; }
    .contact-card-subject { font-size: 0.82rem; font-weight: 500; color: #334155; }
    .contact-card-msg     { font-size: 0.8rem; color: #94a3b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
</style>

<div class="card">
    <div class="card-header">
        <i class="bi bi-envelope me-2 text-success"></i>Gelen Mesajlar
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>Henüz mesaj yok.
            </div>
        }
        else
        {
            /* ── Masaüstü tablo ── */
            <div class="contact-table-wrap">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Ad Soyad</th>
                                <th>E-posta</th>
                                <th>Konu</th>
                                <th>Mesaj</th>
                                <th style="width:110px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-medium">@item.UserName</td>
                                    <td class="text-muted">@item.UserEmail</td>
                                    <td>@item.UserSubject</td>
                                    <td class="text-muted" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @item.Message
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1 justify-content-end">
                                            <a asp-area="Admin" asp-controller="AdminContact" asp-action="Detail"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-primary btn-sm" title="Detay">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-area="Admin" asp-controller="AdminContact" asp-action="Delete"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-danger btn-sm"
                                               onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?')" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            /* ── Mobil kart listesi ── */
            <div class="contact-cards-wrap p-3">
                @foreach (var item in Model)
                {
                    <div class="contact-card">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <div>
                                <div class="contact-card-name">@item.UserName</div>
                                <div class="contact-card-email">@item.UserEmail</div>
                            </div>
                            <div class="d-flex gap-1">
                                <a asp-area="Admin" asp-controller="AdminContact" asp-action="Detail"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-area="Admin" asp-controller="AdminContact" asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-danger btn-sm"
                                   onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(item.UserSubject))
                        {
                            <div class="contact-card-subject mt-1">@item.UserSubject</div>
                        }
                        <div class="contact-card-msg mt-1">@item.Message</div>
                    </div>
                }
            </div>
        }
    </div>
</div>
