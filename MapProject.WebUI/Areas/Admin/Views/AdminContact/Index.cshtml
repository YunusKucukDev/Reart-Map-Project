@model List<ResultContactDto>
@{
    ViewData["Title"] = "Mesajlar";
    ViewData["ActiveMenu"] = "Contact";
}

<div class="card">
    <div class="card-header">
        <i class="bi bi-envelope me-2 text-success"></i>Gelen Mesajlar
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>Henüz mesaj yok.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Ad Soyad</th>
                            <th>E-posta</th>
                            <th>Konu</th>
                            <th>Mesaj</th>
                            <th style="width:110px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-medium">@item.UserName</td>
                                <td class="text-muted">@item.UserEmail</td>
                                <td>@item.UserSubject</td>
                                <td class="text-muted" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    @item.Message
                                </td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-area="Admin" asp-controller="AdminContact" asp-action="Detail"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm" title="Detay">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="AdminContact" asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm"
                                           onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?')" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
