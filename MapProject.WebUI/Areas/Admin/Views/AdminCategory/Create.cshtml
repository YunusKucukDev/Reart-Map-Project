@model CreateCategoryDto
@{
    ViewData["Title"] = "Yeni Kategori";
    ViewData["ActiveMenu"] = "Category";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2 text-primary"></i>Yeni Kategori Ekle</h5>
            </div>
            <div class="card-body p-4">
                <form asp-area="Admin" asp-controller="AdminCategory" asp-action="Create"
                      method="post" enctype="multipart/form-data">

                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label asp-for="CategoryName" class="form-label fw-bold">Kategori Adı <span class="text-danger">*</span></label>
                            <input asp-for="CategoryName" class="form-control" placeholder="Kategori adını girin" />
                            <span asp-validation-for="CategoryName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-bold">Açıklama</label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Kategori açıklaması girin..."></textarea>
                    </div>

                    <hr class="text-muted mb-4" />
                    <h6 class="mb-3 text-secondary">Kategori Görselleri</h6>

                    <div class="row text-center">
                        <div class="col-md-4 mb-3">
                            <label class="form-label d-block fw-bold small">Ana Resim (1)</label>
                            <div class="image-upload-container">
                                <img src="/images/no-image.png" id="preview1" class="img-fluid rounded border mb-2 shadow-sm preview-box" />
                                <input type="file" name="file1" id="file1" class="d-none" accept="image/*" onchange="updatePreview(this, 'preview1')" />
                                <button type="button" class="btn btn-sm btn-outline-primary w-100" onclick="document.getElementById('file1').click()">
                                    <i class="bi bi-camera me-1"></i> Seç
                                </button>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label d-block fw-bold small">Görsel (2)</label>
                            <div class="image-upload-container">
                                <img src="/images/no-image.png" id="preview2" class="img-fluid rounded border mb-2 shadow-sm preview-box" />
                                <input type="file" name="file2" id="file2" class="d-none" accept="image/*" onchange="updatePreview(this, 'preview2')" />
                                <button type="button" class="btn btn-sm btn-outline-primary w-100" onclick="document.getElementById('file2').click()">
                                    <i class="bi bi-camera me-1"></i> Seç
                                </button>
                            </div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label d-block fw-bold small">Görsel (3)</label>
                            <div class="image-upload-container">
                                <img src="/images/no-image.png" id="preview3" class="img-fluid rounded border mb-2 shadow-sm preview-box" />
                                <input type="file" name="file3" id="file3" class="d-none" accept="image/*" onchange="updatePreview(this, 'preview3')" />
                                <button type="button" class="btn btn-sm btn-outline-primary w-100" onclick="document.getElementById('file3').click()">
                                    <i class="bi bi-camera me-1"></i> Seç
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Kategoriyi Oluştur
                        </button>
                        <a asp-action="Index" class="btn btn-light px-4 border">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .preview-box {
            width: 100%;
            height: 140px;
            object-fit: cover;
            background-color: #f8f9fa;
            display: block;
        }

        .image-upload-container:hover img {
            opacity: 0.8;
            transition: 0.3s;
        }
    </style>

    <script>
        function updatePreview(input, previewId) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    document.getElementById(previewId).setAttribute('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}