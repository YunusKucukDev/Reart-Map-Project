@model List<ResultCategoryDto>
@{
    ViewData["Title"] = "Kategoriler";
    ViewData["ActiveMenu"] = "Category";
    // API adresini buraya tanımlıyoruz
    string apiUrl = "https://reart-map-project-api.onrender.com";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-grid-3x3-gap me-2 text-primary"></i>Kategoriler</span>
        <a asp-area="Admin" asp-controller="AdminCategory" asp-action="Create"
           class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Yeni Kategori
        </a>
    </div>
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>Henüz kategori yok.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Kategori Adı</th>
                            <th>Açıklama</th>
                            <th>Resim 1</th>
                            <th>Resim 2</th>
                            <th>Resim 3</th>
                            <th style="width:130px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-medium">@item.CategoryName</td>
                                <td class="text-muted" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@item.Description</td>

                                @* RESİM 1 *@
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl1))
                                    {
                                        <img src="@(apiUrl + item.ImageUrl1)" style="width:40px;height:40px;object-fit:cover;border-radius:4px;border:1px solid #eee;" alt="" />
                                    }
                                    else
                                    {

                                        <span class="text-muted small">Yok</span>
                                    }
                                </td>

                                @* RESİM 2 *@
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl2))
                                    {
                                        <img src="@(apiUrl + item.ImageUrl2)" style="width:40px;height:40px;object-fit:cover;border-radius:4px;border:1px solid #eee;" alt="" />
                                    }
                                    else
                                    {

                                        <span class="text-muted small">-</span>
                                    }
                                </td>

                                @* RESİM 3 *@
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageUrl3))
                                    {
                                        <img src="@(apiUrl + item.ImageUrl3)" style="width:40px;height:40px;object-fit:cover;border-radius:4px;border:1px solid #eee;" alt="" />
                                    }
                                    else
                                    {

                                        <span class="text-muted small">-</span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a asp-area="Admin" asp-controller="AdminCategory" asp-action="ToggleFavorite"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm @(item.IsFavorite ? "btn-warning" : "btn-outline-warning")"
                                           title="@(item.IsFavorite ? "Favoriden Çıkar" : "Favoriye Ekle")">
                                            <i class="bi bi-star@(item.IsFavorite ? "-fill" : "")"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="AdminCategory" asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="AdminCategory" asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-danger btn-sm"
                                           onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>