@model List<ResultMapViewerDto>
@using MapProject.DtoLayer.DTOs.MapViewerDto
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Harita Görüntüleyiciler";
    ViewData["ActiveMenu"] = "MapViewer";
    string apiUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5000").TrimEnd('/');
}

<style>
    /* Kart Stilleri */
    .map-card {
        background: #ffffff;
        border-radius: 1rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        border: 1px solid #e5e7eb;
        transition: all 0.3s ease;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .map-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

    .map-image-wrapper {
        position: relative;
        height: 180px;
        background: #f3f4f6;
    }

    .map-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    /* URL Kutusu */
    .url-box {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 0.5rem;
        font-size: 0.8rem;
        word-break: break-all;
        margin: 0.5rem 0;
        display: block;
        color: #6366f1;
        text-decoration: none;
    }

        .url-box:hover {
            background: #f0fdf4;
            border-color: #bbf7d0;
        }
</style>

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0 text-dark">Haritalarınız</h4>
        <a asp-area="Admin" asp-controller="AdminMapViewer" asp-action="Create" class="btn btn-primary px-4 shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Yeni Harita Ekle
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 border rounded-3 bg-light">
            <i class="bi bi-map display-4 text-muted"></i>
            <p class="mt-3 text-muted">Henüz harita tanımlanmamış.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="map-card">
                        <div class="map-image-wrapper">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@(apiUrl + item.ImageUrl)" class="map-thumb" alt="@item.Title" onerror="this.style.display='none'" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-muted">Görsel Yok</div>
                            }
                        </div>

                        <div class="p-3 flex-grow-1">
                            <h6 class="fw-bold text-dark mb-2">@item.Title</h6>

                            <a href="@item.Url" target="_blank" class="url-box">
                                <i class="bi bi-link-45deg me-1"></i> @item.Url
                            </a>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="badge bg-light text-primary border">
                                    <i class="bi bi-eye-fill me-1"></i>
                                    <span id="viewer-count-@item.Id">@item.ViewCount</span> Görüntülenme
                                </span>
                            </div>
                        </div>

                        <div class="p-3 border-top bg-light d-flex gap-2">
                            <a asp-area="Admin" asp-controller="AdminMapViewer" asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-pencil-square"></i> Düzenle</a>
                            <a asp-area="Admin" asp-controller="AdminMapViewer" asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-outline-danger btn-sm" onclick="return confirm('Bu öğeyi silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        var mapAdminConn = new signalR.HubConnectionBuilder()
            .withUrl("/visitorHub")
            .withAutomaticReconnect()
            .build();

        mapAdminConn.on("UpdateMapViewerCount", function (mapId, count) {
            var el = document.getElementById("viewer-count-" + mapId);
            if (el) el.textContent = count;
        });

        mapAdminConn.start().then(() => mapAdminConn.invoke("RegisterAdmin"));
    </script>
}