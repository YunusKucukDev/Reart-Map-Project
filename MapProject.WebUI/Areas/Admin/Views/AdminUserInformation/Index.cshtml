@model ResultUserInformationDto
@{
    ViewData["Title"] = "Firma Bilgileri";
    ViewData["ActiveMenu"] = "UserInformation";
    string apiUrl = "https://localhost:3000";

    // Resim mantığını tek bir yerde kuruyoruz
    string finalImgSrc = "";
    if (Model != null && !string.IsNullOrEmpty(Model.Image))
    {
        finalImgSrc = Model.Image.StartsWith("http") ? Model.Image : apiUrl + Model.Image;
    }
    else
    {
        finalImgSrc = apiUrl + "/images/no-image.png";
    }
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model != null && !string.IsNullOrEmpty(Model.Id))
{
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0"><i class="bi bi-person-badge me-2 text-warning"></i>Firma Bilgilerini Düzenle</h5>
        </div>
        <div class="card-body p-4">
            <form asp-area="Admin" asp-controller="AdminUserInformation" asp-action="Update"
                  method="post" enctype="multipart/form-data">

                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="mb-4 pb-3 border-bottom">
                    <label class="form-label fw-bold d-block">Firma / Profil Görseli</label>
                    <div class="d-flex align-items-start gap-4 flex-wrap">
                        <div class="position-relative">
                            <img id="imgPreview" src="@finalImgSrc"
                                 class="rounded-3 border shadow-sm"
                                 style="width:140px;height:140px;object-fit:cover; background-color:#f8f9fa;" alt="Logo" />
                        </div>
                        <div class="flex-grow-1">
                            <button type="button" class="btn btn-outline-primary btn-sm mb-2"
                                    onclick="document.getElementById('fileInput').click()">
                                <i class="bi bi-camera me-1"></i> Yeni Görsel Seç
                            </button>
                            <br />
                            <span id="fileName" class="text-muted small">
                                @(string.IsNullOrEmpty(Model.Image) ? "Dosya seçilmedi" : "Mevcut görsel yüklü")
                            </span>

                            <input type="file" id="fileInput" name="file" accept="image/*" class="d-none"
                                   onchange="handleFileChange(this)" />

                            <p class="text-muted small mt-2 mb-0">Öneri: Kare boyutunda (1:1) görseller daha iyi görünür.</p>
                        </div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Ad</label>
                        <input name="Name" value="@Model.Name" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Soyad</label>
                        <input name="Surname" value="@Model.Surname" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Firma Adı</label>
                        <input name="CompanyName" value="@Model.CompanyName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Slogan</label>
                        <input name="Slogan" value="@Model.Slogan" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Başlık</label>
                        <input name="Title" value="@Model.Title" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">E-posta</label>
                        <input name="Email" value="@Model.Email" class="form-control" type="email" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-medium">Telefon</label>
                        <input name="PhoneNumber" value="@Model.PhoneNumber" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">Adres</label>
                        <input name="Address" value="@Model.Address" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">Açıklama</label>
                        <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                    </div>

                    <div class="col-12 pt-3">
                        <h6 class="text-primary border-bottom pb-2">Sosyal Medya Linkleri</h6>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label small"><i class="bi bi-linkedin me-1 text-primary"></i>LinkedIn</label>
                        <input name="LinkednLink" value="@Model.LinkednLink" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small"><i class="bi bi-instagram me-1 text-danger"></i>Instagram</label>
                        <input name="InstagramLink" value="@Model.InstagramLink" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small"><i class="bi bi-twitter-x me-1"></i>X (Twitter)</label>
                        <input name="XLink" value="@Model.XLink" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small"><i class="bi bi-whatsapp me-1 text-success"></i>WhatsApp</label>
                        <input name="WPLink" value="@Model.WPLink" class="form-control form-control-sm" />
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-2"></i>Bilgileri Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm border-primary">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-plus-circle me-2"></i>İlk Firma Bilgisini Oluştur
        </div>
        <div class="card-body p-4 text-center">
            <form asp-area="Admin" asp-controller="AdminUserInformation" asp-action="Create"
                  method="post" enctype="multipart/form-data">

                <div class="mb-4">
                    <img id="imgPreview" src="@(apiUrl + "/images/no-image.png")"
                         class="rounded-circle border mb-2" style="width:120px;height:120px;object-fit:cover;" />
                    <br />
                    <input type="file" name="file" id="fileInput" class="d-none" onchange="handleFileChange(this)" />
                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="document.getElementById('fileInput').click()">Logo Seç</button>
                    <div id="fileName" class="small text-muted mt-1"></div>
                </div>

                <div class="row g-3 text-start">
                    <div class="col-md-6"><label class="form-label">Ad</label><input name="Name" class="form-control" required /></div>
                    <div class="col-md-6"><label class="form-label">Soyad</label><input name="Surname" class="form-control" required /></div>
                    <div class="col-12"><label class="form-label">Firma Adı</label><input name="CompanyName" class="form-control" required /></div>
                    <div class="col-12"><button type="submit" class="btn btn-success w-100">Kaydet ve Başlat</button></div>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script>
        function handleFileChange(input) {
            const file = input.files[0];
            if (!file) return;

            const fileNameDisplay = document.getElementById('fileName');
            if(fileNameDisplay) fileNameDisplay.textContent = file.name;

            const reader = new FileReader();
            reader.onload = e => {
                const img = document.getElementById('imgPreview');
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        }
    </script>
}