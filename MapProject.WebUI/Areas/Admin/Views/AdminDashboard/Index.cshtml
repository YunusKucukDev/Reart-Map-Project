@using MapProject.DtoLayer.DTOs.VisitorLogDto
@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "Dashboard";
    var recentVisitors = ViewBag.RecentVisitors as List<ResultVisitorLogDto> ?? new();
}

<style>
    .stat-card-wrap {
        border-radius: 0.75rem; padding: 1.4rem 1.5rem; color: #fff;
        position: relative; overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,.12);
        transition: transform .2s, box-shadow .2s;
    }
    .stat-card-wrap:hover { transform: translateY(-3px); box-shadow: 0 8px 22px rgba(0,0,0,.16); }
    .stat-card-wrap .bg-icon { position: absolute; right: -10px; bottom: -10px; font-size: 5rem; opacity: .12; }
    .quick-card {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 0.75rem; padding: 1.75rem 1rem; border-radius: 0.75rem;
        text-decoration: none; color: inherit; border: 2px solid transparent;
        background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,.07);
        transition: all .2s ease;
    }
    .quick-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,.13); color: inherit; }
    .quick-card .qc-icon { width: 58px; height: 58px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.55rem; }
    .quick-card .qc-label { font-size: 0.88rem; font-weight: 600; color: #334155; text-align: center; }
    .quick-card .qc-sub   { font-size: 0.76rem; color: #94a3b8; text-align: center; }
    .quick-card.qc-blue:hover  { border-color: #3b82f6; }
    .quick-card.qc-green:hover { border-color: #10b981; }
    .quick-card.qc-amber:hover { border-color: #f59e0b; }
    .quick-card.qc-cyan:hover  { border-color: #06b6d4; }
    @@keyframes pulse {
        0%   { opacity: 1; transform: scale(1); }
        50%  { opacity: .45; transform: scale(1.25); }
        100% { opacity: 1; transform: scale(1); }
    }
</style>

<!-- İstatistik Kartları -->
<div class="row g-4 mb-4">

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card-wrap" style="background:linear-gradient(135deg,#3b82f6,#1d4ed8);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold lh-1">@ViewBag.CategoryCount</div>
                    <div class="opacity-75 mt-2 small">Toplam Kategori</div>
                </div>
                <div style="background:rgba(255,255,255,.15);border-radius:50%;width:48px;height:48px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-grid-3x3-gap fs-4"></i>
                </div>
            </div>
            <i class="bi bi-grid-3x3-gap bg-icon"></i>
        </div>
    </div>

    <div class="col-sm-6 col-xl-3">
        <div class="stat-card-wrap" style="background:linear-gradient(135deg,#10b981,#047857);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold lh-1">@ViewBag.ContactCount</div>
                    <div class="opacity-75 mt-2 small">Toplam Mesaj</div>
                </div>
                <div style="background:rgba(255,255,255,.15);border-radius:50%;width:48px;height:48px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-envelope fs-4"></i>
                </div>
            </div>
            <i class="bi bi-envelope bg-icon"></i>
        </div>
    </div>

    <!-- Toplam Ziyaretçi (DB'den) -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card-wrap" style="background:linear-gradient(135deg,#f59e0b,#b45309);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold lh-1">@ViewBag.TotalVisitors</div>
                    <div class="opacity-75 mt-2 small">Toplam Ziyaretçi</div>
                </div>
                <div style="background:rgba(255,255,255,.15);border-radius:50%;width:48px;height:48px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-bar-chart-line fs-4"></i>
                </div>
            </div>
            <i class="bi bi-bar-chart-line bg-icon"></i>
        </div>
    </div>

    <!-- Anlık Ziyaretçi (SignalR) -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card-wrap" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9);">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <div class="fs-2 fw-bold lh-1 d-flex align-items-center gap-2">
                        <span id="visitorCount">0</span>
                        <span style="width:10px;height:10px;border-radius:50%;background:#a78bfa;display:inline-block;animation:pulse 1.4s infinite;"></span>
                    </div>
                    <div class="opacity-75 mt-2 small">Anlık Ziyaretçi</div>
                </div>
                <div style="background:rgba(255,255,255,.15);border-radius:50%;width:48px;height:48px;display:flex;align-items:center;justify-content:center;">
                    <i class="bi bi-people fs-4"></i>
                </div>
            </div>
            <i class="bi bi-people bg-icon"></i>
        </div>
    </div>

</div>

<!-- Chart + Son Ziyaretçiler -->
<div class="row g-4 mb-4">

    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-graph-up text-primary"></i>
                <span>Son 7 Gün Ziyaretçi Grafiği</span>
            </div>
            <div class="card-body">
                <canvas id="visitorChart" height="110"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-clock-history text-secondary"></i>
                <span>Son Ziyaretçiler</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Tarih / Saat</th>
                                <th>IP Adresi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in recentVisitors)
                            {
                                <tr>
                                    <td class="text-nowrap">@v.VisitedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@v.IpAddress</span>
                                    </td>
                                </tr>
                            }
                            @if (!recentVisitors.Any())
                            {
                                <tr><td colspan="2" class="text-center text-muted py-3">Henüz ziyaretçi yok</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Hızlı Erişim -->
<div class="card mb-2">
    <div class="card-header d-flex align-items-center gap-2">
        <i class="bi bi-lightning-charge-fill text-warning"></i>
        <span>Hızlı Erişim</span>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <a asp-area="Admin" asp-controller="AdminCategory" asp-action="Index" class="quick-card qc-blue">
                    <div class="qc-icon" style="background:#eff6ff;color:#3b82f6;"><i class="bi bi-grid-3x3-gap"></i></div>
                    <div class="qc-label">Kategoriler</div>
                    <div class="qc-sub">Yönet &amp; Düzenle</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-area="Admin" asp-controller="AdminContact" asp-action="Index" class="quick-card qc-green">
                    <div class="qc-icon" style="background:#f0fdf4;color:#10b981;"><i class="bi bi-envelope"></i></div>
                    <div class="qc-label">Mesajlar</div>
                    <div class="qc-sub">Gelen Kutusu</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-area="Admin" asp-controller="AdminUserInformation" asp-action="Index" class="quick-card qc-amber">
                    <div class="qc-icon" style="background:#fffbeb;color:#f59e0b;"><i class="bi bi-person-badge"></i></div>
                    <div class="qc-label">Firma Bilgileri</div>
                    <div class="qc-sub">Profil &amp; Detay</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-area="Admin" asp-controller="AdminMapIdentityDescription" asp-action="Index" class="quick-card qc-cyan">
                    <div class="qc-icon" style="background:#ecfeff;color:#06b6d4;"><i class="bi bi-map"></i></div>
                    <div class="qc-label">Harita Tanımı</div>
                    <div class="qc-sub">Konum &amp; Açıklama</div>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        // --- Ziyaretçi Grafiği ---
        var labels = @Html.Raw(ViewBag.DailyLabels);
        var data   = @Html.Raw(ViewBag.DailyData);

        new Chart(document.getElementById("visitorChart"), {
            type: "bar",
            data: {
                labels: labels,
                datasets: [{
                    label: "Ziyaretçi",
                    data: data,
                    backgroundColor: "rgba(139,92,246,0.25)",
                    borderColor: "#8b5cf6",
                    borderWidth: 2,
                    borderRadius: 6,
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: "#f1f5f9" } },
                    x: { grid: { display: false } }
                }
            }
        });

        // --- SignalR: Anlık Ziyaretçi ---
        var adminConn = new signalR.HubConnectionBuilder()
            .withUrl("/visitorHub")
            .withAutomaticReconnect()
            .build();

        adminConn.on("UpdateVisitorCount", function (count) {
            document.getElementById("visitorCount").textContent = count;
        });

        adminConn.start()
            .then(function () { return adminConn.invoke("RegisterAdmin"); })
            .catch(function (err) { console.error("Admin SignalR hatası:", err); });
    </script>
}
